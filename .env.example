# Application Settings
APP_NAME=BABE_Crawler
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Database Configuration
DB_TYPE=postgresql  # postgresql, mongodb, sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=crawler_user
DB_PASSWORD=secure_password
DB_NAME=crawler_db

# MongoDB (if using MongoDB)
MONGODB_URI=mongodb://localhost:27017/crawler_db

# Redis Configuration (for caching/queuing)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Proxy Settings
USE_PROXY=False
PROXY_LIST_URL=
PROXY_UPDATE_INTERVAL=3600

# Scraper Settings
MAX_WORKERS=5
REQUEST_TIMEOUT=10
RETRY_ATTEMPTS=3
RETRY_DELAY=5
USER_AGENT_FILE=config/user_agents.txt

# Output Settings
OUTPUT_FORMAT=json  # json, csv, database
OUTPUT_PATH=./data/

# Logging
LOG_FILE=logs/crawler.log
LOG_FORMAT=json  # json, text

# Features
ENABLE_CACHE=True
ENABLE_PROXY_ROTATION=False
ENABLE_USER_AGENT_ROTATION=True
RESPECT_ROBOTS_TXT=True
RESPECT_CRAWL_DELAY=True

# API Settings (optional)
API_ENABLED=False
API_HOST=0.0.0.0
API_PORT=8000

# Notification Settings
ENABLE_NOTIFICATIONS=False
NOTIFICATION_EMAIL=
SLACK_WEBHOOK_URL=
